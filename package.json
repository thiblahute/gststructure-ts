{
  "name": "gststructure",
  "version": "0.1.1",
  "description": "Pure TypeScript parser for GStreamer Structure and Caps serialization format",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepare": "npm run build",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "gstreamer",
    "gststructure",
    "gstcaps",
    "parser"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/thiblahute/gststructure-ts.git"
  },
  "bugs": {
    "url": "https://github.com/thiblahute/gststructure-ts/issues"
  },
  "homepage": "https://github.com/thiblahute/gststructure-ts#readme",
  "devDependencies": {
    "prettier": "^3.8.3",
    "typescript": "^5.0.0",
    "vitest": "^2.0.0"
  }
}
